<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title><%= stream.name %> - Futbol Online</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="/socket.io/socket.io.js"></script>
    <link href="https://vjs.zencdn.net/8.10.0/video-js.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { height: 100%; width: 100%; overflow: hidden; font-family: 'Poppins', sans-serif; background: #000; color: white; -webkit-tap-highlight-color: transparent; }
        body { display: flex; }
        .main-wrapper { flex: 1; display: flex; flex-direction: column; height: 100vh; height: 100dvh; width: 100%; overflow: hidden; }
        .stream-header { display: flex; justify-content: space-between; align-items: center; padding: 8px 12px; background: rgba(15,15,26,0.95); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255,255,255,0.06); z-index: 50; flex-shrink: 0; gap: 6px; min-height: 44px; }
        .stream-header-left { display: flex; align-items: center; gap: 6px; flex: 1; min-width: 0; }
        .back-btn { width: 32px; height: 32px; border-radius: 8px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1); color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; text-decoration: none; font-size: 14px; flex-shrink: 0; }
        .live-badge { background: #ea4335; color: white; padding: 3px 8px; border-radius: 20px; font-size: 9px; font-weight: 700; display: flex; align-items: center; gap: 4px; text-transform: uppercase; letter-spacing: 1px; flex-shrink: 0; }
        .live-dot { width: 6px; height: 6px; background: white; border-radius: 50%; }
        .stream-name-header { font-size: 12px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .server-selector { display: flex; align-items: center; gap: 4px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; padding: 3px 6px; max-width: 150px; }
        .server-selector i { color: #667eea; font-size: 10px; }
        .server-selector select { background: transparent; border: none; color: white; font-family: 'Poppins', sans-serif; font-size: 10px; cursor: pointer; outline: none; flex: 1; min-width: 0; }
        .server-selector select option { background: #1a1a2e; color: white; }
        .stream-header-right { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
        .viewers-badge { background: rgba(255,255,255,0.08); padding: 3px 8px; border-radius: 20px; font-size: 10px; display: flex; align-items: center; gap: 4px; border: 1px solid rgba(255,255,255,0.1); white-space: nowrap; }
        .viewers-badge i { color: #34a853; font-size: 9px; }
        .viewers-count-number { font-weight: 700; color: #34a853; }
        .mobile-server-btn { display: none; background: rgba(102,126,234,0.2); border: 1px solid #667eea; color: white; padding: 4px 8px; border-radius: 6px; cursor: pointer; font-family: 'Poppins', sans-serif; font-size: 9px; white-space: nowrap; }
        .stream-content { flex: 1; display: flex; overflow: hidden; min-height: 0; width: 100%; }
        .video-container { flex: 1; background: #000; display: flex; align-items: center; justify-content: center; position: relative; min-width: 0; overflow: hidden; }
        .player-wrapper { width: 100%; height: 100%; position: absolute; top: 0; left: 0; background: #000; }
        .player-wrapper video { width: 100%; height: 100%; object-fit: contain; position: absolute; top: 0; left: 0; }
        .player-wrapper iframe { width: 100%; height: 100%; border: none; position: absolute; top: 0; left: 0; }
        .click-shield { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 10; background: transparent; pointer-events: auto; }
        .server-change-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); display: none; align-items: center; justify-content: center; z-index: 30; flex-direction: column; gap: 12px; }
        .server-change-overlay.active { display: flex; }
        .server-change-spinner { width: 36px; height: 36px; border: 3px solid rgba(255,255,255,0.1); border-top-color: #667eea; border-radius: 50%; animation: spin 0.8s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }
        .server-change-text { color: #aaa; font-size: 12px; }
        .chat-sidebar { width: 340px; background: #0f0f1a; border-left: 1px solid rgba(255,255,255,0.08); display: flex; flex-direction: column; flex-shrink: 0; height: 100%; }
        .chat-header { padding: 8px 12px; border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; gap: 4px; flex-wrap: wrap; min-height: 40px; }
        .chat-header h3 { font-size: 12px; font-weight: 600; display: flex; align-items: center; gap: 4px; margin: 0; }
        .chat-header h3 i { color: #34a853; font-size: 7px; }
        .chat-server-name { font-size: 9px; color: #667eea; background: rgba(102,126,234,0.1); padding: 2px 6px; border-radius: 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 80px; }
        .chat-online-count { font-size: 9px; color: #888; white-space: nowrap; }
        .chat-messages { flex: 1; overflow-y: auto; overflow-x: hidden; padding: 8px; display: flex; flex-direction: column; gap: 6px; min-height: 0; -webkit-overflow-scrolling: touch; }
        .chat-messages::-webkit-scrollbar { width: 3px; }
        .chat-messages::-webkit-scrollbar-track { background: transparent; }
        .chat-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 10px; }
        .chat-message { display: flex; gap: 6px; flex-shrink: 0; }
        .message-avatar { width: 24px; height: 24px; border-radius: 50%; border: 2px solid #667eea; object-fit: cover; flex-shrink: 0; }
        .message-content { flex: 1; min-width: 0; }
        .message-header { display: flex; align-items: center; gap: 3px; margin-bottom: 1px; flex-wrap: wrap; }
        .message-username { font-weight: 600; font-size: 10px; }
        .role-badge-mini { padding: 1px 4px; border-radius: 3px; font-size: 6px; font-weight: 700; text-transform: uppercase; flex-shrink: 0; }
        .role-owner { background: #ffd700; color: #000; }
        .role-admin { background: #ea4335; color: white; }
        .role-user { background: #4a90e2; color: white; }
        .message-text { font-size: 10px; color: #ddd; line-height: 1.4; word-break: break-word; }
        .message-time { font-size: 7px; color: #555; margin-left: auto; flex-shrink: 0; }
        .chat-input-container { padding: 6px 8px; border-top: 1px solid rgba(255,255,255,0.08); flex-shrink: 0; background: #0f0f1a; }
        .chat-input-wrapper { display: flex; gap: 6px; align-items: center; }
        .chat-input { flex: 1; padding: 8px 10px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; color: white; font-size: 11px; font-family: 'Poppins',sans-serif; transition: all 0.3s; min-width: 0; -webkit-appearance: none; }
        .chat-input:focus { outline: none; border-color: #667eea; background: rgba(255,255,255,0.1); }
        .chat-input::placeholder { color: #555; }
        .chat-send-btn { width: 32px; height: 32px; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); border: none; color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 12px; flex-shrink: 0; }
        .chat-send-btn:active { transform: scale(0.9); }
        .servers-panel { display: none; position: fixed; bottom: 0; left: 0; width: 100%; max-height: 50vh; background: rgba(15,15,26,0.98); backdrop-filter: blur(20px); border-top: 1px solid rgba(255,255,255,0.1); border-radius: 14px 14px 0 0; z-index: 200; overflow-y: auto; padding: 12px; -webkit-overflow-scrolling: touch; }
        .servers-panel.active { display: block; }
        .servers-panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
        .servers-panel-header h3 { font-size: 13px; display: flex; align-items: center; gap: 4px; }
        .servers-panel-close { background: rgba(255,255,255,0.1); border: none; color: white; width: 26px; height: 26px; border-radius: 50%; cursor: pointer; font-size: 11px; }
        .server-btn { display: flex; align-items: center; gap: 6px; width: 100%; padding: 10px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; color: white; cursor: pointer; margin-bottom: 5px; font-family: 'Poppins', sans-serif; font-size: 11px; text-align: left; }
        .server-btn:active { background: rgba(102,126,234,0.2); }
        .server-btn.active { background: rgba(102,126,234,0.2); border-color: #667eea; }
        .server-btn i { color: #667eea; font-size: 11px; }
        .servers-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 199; }
        .servers-overlay.active { display: block; }
        @media (max-width: 1024px) { .stream-content { flex-direction: column; } .video-container { height: 45vh; flex: none; min-height: 200px; } .chat-sidebar { width: 100%; flex: 1; min-height: 250px; } .server-selector { display: none; } .mobile-server-btn { display: block; } .chat-input-container { position: sticky; bottom: 0; } }
        @media (max-width: 768px) { .stream-header { padding: 6px 8px; min-height: 40px; } .video-container { height: 35vh; min-height: 180px; } .viewers-badge span:last-child { display: none; } }
        @media (max-width: 480px) { .video-container { height: 30vh; min-height: 160px; } .chat-sidebar { min-height: 250px; } .chat-input { font-size: 16px; } .chat-send-btn { width: 36px; height: 36px; } }
    </style>
</head>
<body>
    <div class="main-wrapper">
        <header class="stream-header">
            <div class="stream-header-left"><a href="/dashboard" class="back-btn"><i class="fas fa-arrow-left"></i></a><div class="live-badge"><span class="live-dot"></span> DIRECTO</div><span class="stream-name-header"><%= stream.name %></span><div class="server-selector"><i class="fas fa-server"></i><select id="serverSelect" onchange="changeServer()"><option value="">Cargando...</option></select></div><button class="mobile-server-btn" onclick="openServersPanel()"><i class="fas fa-list"></i> Servidores</button></div>
            <div class="stream-header-right"><div class="viewers-badge"><i class="fas fa-eye"></i> <span class="viewers-count-number" id="viewerCount">0</span> <span>espectadores</span></div></div>
        </header>
        <div class="stream-content">
            <div class="video-container" id="videoContainer">
                <div class="server-change-overlay active" id="serverChangeOverlay"><div class="server-change-spinner"></div><p class="server-change-text">Cargando transmisión...</p></div>
                <div class="player-wrapper" id="playerWrapper"></div>
                <div class="click-shield" id="clickShield"></div>
            </div>
            <div class="chat-sidebar">
                <div class="chat-header"><h3><i class="fas fa-circle"></i> Chat</h3><span class="chat-server-name" id="chatServerName">Principal</span><span class="chat-online-count" id="chatOnlineCount">0</span></div>
                <div class="chat-messages" id="chatMessages"><div style="text-align:center;padding:25px;color:#555;"><i class="fas fa-comments" style="font-size:28px;display:block;margin-bottom:6px;opacity:0.3;"></i><p style="font-size:10px;">Sé el primero en comentar</p></div></div>
                <div class="chat-input-container"><div class="chat-input-wrapper"><input type="text" id="chatInput" class="chat-input" placeholder="Escribe un mensaje..." maxlength="200" autocomplete="off"><button class="chat-send-btn" onclick="sendMessage()"><i class="fas fa-paper-plane"></i></button></div></div>
            </div>
        </div>
    </div>
    <div class="servers-overlay" id="serversOverlay" onclick="closeServersPanel()"></div>
    <div class="servers-panel" id="serversPanel"><div class="servers-panel-header"><h3><i class="fas fa-server"></i> Servidores</h3><button class="servers-panel-close" onclick="closeServersPanel()"><i class="fas fa-times"></i></button></div><div id="serversList"></div></div>

    <script src="https://vjs.zencdn.net/8.10.0/video.min.js"></script>
    <script>
        const streamId='<%= stream.id %>',userId='<%= user.id %>',username='<%= user.username %>',userRole='<%= user.role %>',userAvatar='<%= user.avatar %>';
        const socket=io();
        let hls=null,lastMessageTime=0;
        const streamUrl='<%- stream.url %>';
        let currentServerUrl=streamUrl,currentServerName='Principal';

        const servers=[
            {server:"Servidor Principal",code:streamUrl},
            {server:"DSports HD",code:"https://la16hd.com/dsportsar.php"},
            {server:"DSports +",code:"https://tvhd2.com/vivo/canales.php?stream=dsportsplus"},
            {server:"Telemundo",code:"https://tvhd2.com/vivo/canales.php?stream=telemundo"},
            {server:"TyC Sports",code:"https://tvhd2.com/vivo/canales.php?stream=tycsports"},
            {server:"DAZN Mundial",code:"https://zonatvlive.xyz/tvtodo/dazn-mundial.php"},
            {server:"Fox Sports",code:"https://tvhd2.com/vivo/canales.php?stream=foxsports"},
            {server:"Fox Sports 2",code:"https://tvhd2.com/vivo/canales.php?stream=foxsports2"},
            {server:"Fox Sports 3",code:"https://tvhd2.com/vivo/canales.php?stream=foxsports3"},
            {server:"TnT Sports",code:"https://tvhd2.com/vivo/canales.php?stream=tntsports"},
            {server:"ESPN Premium",code:"https://tvhd2.com/vivo/canales.php?stream=espnpremium"},
            {server:"ESPN 6",code:"https://tvhd2.com/vivo/canales.php?stream=espn6"},
            {server:"Win Sports Plus",code:"https://tvhd2.com/vivo/canales.php?stream=winsports2"},
            {server:"Noticias CaracolTV",code:"https://us-b4-p-e-ml19.cdn.mdstrm.com/live-stream-gdai/632391734be92a791e2750e6/linear/hls/pa/event/AImtl9u6QA2hQXyM7DGbwg/stream/f842358f-8683-4d9f-88c3-26e16a7f78f4:DLS/variant/1efcaebae726efe8207bcd47027366cc/bandwidth/1078000.m3u8"},
            {server:"Univision",code:"https://tvhd2.com/vivo/canales.php?stream=univision"},
            {server:"Canal 5",code:"https://tvhd2.com/vivo/canales.php?stream=canal5"}
        ];

        const serverChats={};let loadedServers={};
        servers.forEach((s,i)=>{serverChats[i]=[];loadedServers[i]=false;});

        function populateServerSelectors(){
            document.getElementById('serverSelect').innerHTML=servers.map((s,i)=>'<option value="'+i+'" '+(s.code===streamUrl?'selected':'')+'>'+s.server+'</option>').join('');
            document.getElementById('serversList').innerHTML=servers.map((s,i)=>'<button class="server-btn '+(s.code===currentServerUrl?'active':'')+'" onclick="selectServer('+i+')"><i class="fas fa-play-circle"></i> '+s.server+'</button>').join('');
        }
        populateServerSelectors();

        function destroyPlayer(){if(hls){hls.stopLoad();hls.detachMedia();hls.destroy();hls=null;}document.getElementById('playerWrapper').innerHTML='';}

        function loadStream(url){
            destroyPlayer();
            document.getElementById('serverChangeOverlay').classList.add('active');
            const w=document.getElementById('playerWrapper');
            if(url.includes('.php')||url.includes('canal.php')||url.includes('canales.php')){
                const iframe=document.createElement('iframe');
                iframe.id='streamIframe';
                iframe.allow='autoplay;fullscreen;encrypted-media;picture-in-picture';
                iframe.referrerPolicy='no-referrer';
                iframe.src=url;
                iframe.style.cssText='width:100%;height:100%;border:none;position:absolute;top:0;left:0;';
                w.appendChild(iframe);
                iframe.onload=()=>document.getElementById('serverChangeOverlay').classList.remove('active');
                setTimeout(()=>document.getElementById('serverChangeOverlay').classList.remove('active'),6000);
            }else if(url.endsWith('.m3u8')||url.includes('m3u8')){
                const v=document.createElement('video');
                v.id='videoPlayer';v.controls=true;v.autoplay=true;v.playsInline=true;
                v.setAttribute('playsinline','');v.setAttribute('webkit-playsinline','');
                v.style.cssText='width:100%;height:100%;object-fit:contain;position:absolute;top:0;left:0;';
                w.appendChild(v);
                if(Hls.isSupported()){hls=new Hls({enableWorker:true,lowLatencyMode:true});hls.loadSource(url);hls.attachMedia(v);hls.on(Hls.Events.MANIFEST_PARSED,()=>{v.play().catch(()=>{});document.getElementById('serverChangeOverlay').classList.remove('active');});}
                else if(v.canPlayType('application/vnd.apple.mpegurl')){v.src=url;v.addEventListener('loadedmetadata',()=>{v.play();document.getElementById('serverChangeOverlay').classList.remove('active');});}
            }else{
                const v=document.createElement('video');
                v.id='videoPlayer';v.controls=true;v.autoplay=true;v.playsInline=true;
                v.setAttribute('playsinline','');v.setAttribute('webkit-playsinline','');v.src=url;
                v.style.cssText='width:100%;height:100%;object-fit:contain;position:absolute;top:0;left:0;';
                w.appendChild(v);
                v.addEventListener('playing',()=>document.getElementById('serverChangeOverlay').classList.remove('active'));
                setTimeout(()=>document.getElementById('serverChangeOverlay').classList.remove('active'),5000);
            }
        }

        function changeServer(){const i=document.getElementById('serverSelect').value;if(i!=='')selectServer(parseInt(i));}
        async function selectServer(i){const s=servers[i];if(!s||(s.code===currentServerUrl&&s.server===currentServerName))return;const p=getCurrentServerIndex();currentServerUrl=s.code;currentServerName=s.server;document.getElementById('chatServerName').textContent=s.server;document.getElementById('serverSelect').value=i;document.querySelectorAll('.server-btn').forEach((b,j)=>b.classList.toggle('active',j===i));closeServersPanel();socket.emit('leave-server-chat',{streamId,serverIndex:p});socket.emit('join-server-chat',{streamId,serverIndex:i});await loadServerMessages(i);loadStream(currentServerUrl);}
        function getCurrentServerIndex(){for(let i=0;i<servers.length;i++){if(servers[i].server===currentServerName)return i;}return 0;}
        async function loadServerMessages(i){if(loadedServers[i]&&serverChats[i].length>0){displayCurrentServerChat(i);return;}try{const r=await fetch('/stream/chat/'+streamId+'?server='+i);const m=await r.json();if(m&&m.length>0){serverChats[i]=m;loadedServers[i]=true;}}catch(e){}displayCurrentServerChat(i);}
        function displayCurrentServerChat(i){const c=document.getElementById('chatMessages');c.innerHTML='';const m=serverChats[i]||[];if(m.length>0)m.forEach(msg=>addMsg(msg));else c.innerHTML='<div style="text-align:center;padding:25px;color:#555;"><i class="fas fa-comments" style="font-size:28px;display:block;margin-bottom:6px;opacity:0.3;"></i><p style="font-size:10px;">Sé el primero en comentar</p></div>';scrollChat();}
        function addMsg(d){const c=document.getElementById('chatMessages');if(c.querySelector('div[style]'))c.innerHTML='';const div=document.createElement('div');div.className='chat-message';const rc='role-'+(d.role||'user');const rt=(d.role||'user').charAt(0).toUpperCase()+(d.role||'user').slice(1);const t=d.timestamp||d.created_at?new Date(d.timestamp||d.created_at).toLocaleTimeString('es-ES',{hour:'2-digit',minute:'2-digit'}):new Date().toLocaleTimeString('es-ES',{hour:'2-digit',minute:'2-digit'});div.innerHTML='<img src="'+(d.avatar||'/uploads/avatars/default.png')+'" class="message-avatar" onerror="this.src=\'/uploads/avatars/default.png\'"><div class="message-content"><div class="message-header"><span class="message-username" style="color:'+getRC(d.role)+'">'+esc(d.username)+'</span><span class="role-badge-mini '+rc+'">'+rt+'</span><span class="message-time">'+t+'</span></div><div class="message-text">'+esc(d.message||'')+'</div></div>';c.appendChild(div);scrollChat();}
        function getRC(r){const o={owner:'#ffd700',admin:'#ea4335',user:'#4a90e2'};return o[r]||'#fff';}
        function scrollChat(){const c=document.getElementById('chatMessages');if(c){c.scrollTop=c.scrollHeight;}}

        socket.on('viewer-count',(c)=>{document.getElementById('viewerCount').textContent=c;document.getElementById('chatOnlineCount').textContent=c;});
        socket.on('new-server-message',function(d){const ci=getCurrentServerIndex();if(d.serverIndex!==undefined){if(!serverChats[d.serverIndex])serverChats[d.serverIndex]=[];serverChats[d.serverIndex].push(d);}if(d.serverIndex===ci)addMsg(d);});
        socket.on('mute-notification',function(data){const c=document.getElementById('chatMessages');const div=document.createElement('div');div.style.cssText='text-align:center;padding:8px;color:#ea4335;font-size:10px;background:rgba(234,67,53,0.1);border:1px solid rgba(234,67,53,0.3);border-radius:6px;margin:4px 0;';div.innerHTML='<i class="fas fa-microphone-slash"></i> '+data.message;c.appendChild(div);scrollChat();});

        function sendMessage(){const inp=document.getElementById('chatInput'),msg=inp.value.trim();if(!msg||Date.now()-lastMessageTime<1000||msg.length>200)return;if(containsLink(msg))return;const si=getCurrentServerIndex();const md={streamId,serverIndex:si,userId,username,avatar:userAvatar,role:userRole,message:msg,timestamp:new Date()};if(!serverChats[si])serverChats[si]=[];serverChats[si].push(md);socket.emit('server-chat-message',md);fetch('/stream/chat/'+streamId,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({message:msg,serverIndex:si})}).catch(()=>{});inp.value='';lastMessageTime=Date.now();inp.focus();}
        document.getElementById('chatInput').addEventListener('keypress',(e)=>{if(e.key==='Enter'){e.preventDefault();sendMessage();}});
        function containsLink(text){return/(https?:\/\/|www\.|\.com|\.net|\.org|\.xyz|\.tv|\.live|\.php|\.m3u8|\.mp4)/i.test(text);}
        function openServersPanel(){document.getElementById('serversPanel').classList.add('active');document.getElementById('serversOverlay').classList.add('active');}
        function closeServersPanel(){document.getElementById('serversPanel').classList.remove('active');document.getElementById('serversOverlay').classList.remove('active');}
        function esc(t){if(!t)return'';const d=document.createElement('div');d.textContent=t;return d.innerHTML;}

        // ============ PROTECCIÓN TOTAL ============
        (function(){
            const shield=document.getElementById('clickShield');
            if(!shield)return;
            ['click','dblclick','mousedown','mouseup','touchstart','touchend','touchmove','pointerdown','pointerup','contextmenu'].forEach(e=>{
                shield.addEventListener(e,function(ev){ev.preventDefault();ev.stopPropagation();ev.stopImmediatePropagation();return false;},true);
            });
            window.open=function(){return null;};
            setInterval(()=>{
                const iframe=document.getElementById('streamIframe');
                if(iframe&&iframe.src&&iframe.src!=='about:blank'&&iframe.src!==currentServerUrl){
                    const ok=servers.some(s=>{try{return iframe.src.includes(new URL(s.code).hostname);}catch(e){return false;}});
                    if(!ok)iframe.src=currentServerUrl;
                }
            },1000);
        })();

        currentServerName=servers[0].server;
        document.getElementById('chatServerName').textContent=currentServerName;
        loadStream(streamUrl);
        loadServerMessages(0);
        socket.emit('join-server-chat',{streamId,serverIndex:0});
    </script>
</body>
</html>
