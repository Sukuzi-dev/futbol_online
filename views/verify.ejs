<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verificar Email - Futbol Online</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        
        .verify-container {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 24px;
            padding: 50px 40px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            max-width: 450px;
            width: 100%;
            text-align: center;
            animation: slideIn 0.5s ease;
        }
        
        @keyframes slideIn {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .verify-icon {
            width: 90px;
            height: 90px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 25px;
            animation: bounce 2s infinite;
        }
        
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        
        .verify-icon i {
            font-size: 40px;
            color: white;
        }
        
        .verify-title {
            color: #1a1a2e;
            font-size: 26px;
            font-weight: 700;
            margin-bottom: 12px;
        }
        
        .verify-description {
            color: #6c757d;
            font-size: 15px;
            margin-bottom: 30px;
            line-height: 1.6;
        }
        
        .code-inputs {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-bottom: 30px;
        }
        
        .code-input {
            width: 50px;
            height: 60px;
            border: 2px solid rgba(0,0,0,0.1);
            border-radius: 12px;
            text-align: center;
            font-size: 24px;
            font-weight: 700;
            color: #1a1a2e;
            transition: all 0.3s ease;
            background: rgba(255,255,255,0.9);
            font-family: 'Poppins', sans-serif;
        }
        
        .code-input:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
            transform: translateY(-3px);
        }
        
        .code-input.filled {
            border-color: #667eea;
            background: rgba(102, 126, 234, 0.05);
        }
        
        .code-input.error {
            border-color: #ea4335;
            animation: shake 0.5s;
        }
        
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            75% { transform: translateX(10px); }
        }
        
        .btn-verify {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-family: 'Poppins', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        
        .btn-verify:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
        }
        
        .btn-verify:disabled {
            opacity: 0.7;
            cursor: not-allowed;
            transform: none;
        }
        
        .loading-spinner {
            display: none;
            width: 20px;
            height: 20px;
            border: 2px solid rgba(255,255,255,0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }
        
        @keyframes spin { to { transform: rotate(360deg); } }
        
        .btn-verify.loading .loading-spinner { display: inline-block; }
        .btn-verify.loading .btn-text { display: none; }
        
        .resend-section {
            margin-top: 25px;
        }
        
        .resend-btn {
            background: none;
            border: none;
            color: #667eea;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.3s;
            font-family: 'Poppins', sans-serif;
            text-decoration: none;
        }
        
        .resend-btn:hover {
            color: #764ba2;
            text-decoration: underline;
        }
        
        .resend-btn:disabled {
            color: #999;
            cursor: not-allowed;
            text-decoration: none;
        }
        
        .timer {
            color: #888;
            font-size: 13px;
            margin-top: 8px;
        }
        
        .timer.warning {
            color: #ea4335;
            font-weight: 500;
        }
        
        .message {
            padding: 12px 16px;
            border-radius: 10px;
            margin-top: 20px;
            display: none;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            animation: slideDown 0.3s ease;
        }
        
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .message.success {
            background: rgba(52, 168, 83, 0.1);
            border: 1px solid #34a853;
            color: #34a853;
        }
        
        .message.error {
            background: rgba(234, 67, 53, 0.1);
            border: 1px solid #ea4335;
            color: #ea4335;
        }
        
        .message.info {
            background: rgba(102, 126, 234, 0.1);
            border: 1px solid #667eea;
            color: #667eea;
        }
        
        .message.show { display: flex; }
        
        .back-link {
            display: block;
            margin-top: 20px;
            color: #888;
            text-decoration: none;
            font-size: 14px;
            transition: all 0.3s;
        }
        
        .back-link:hover {
            color: #667eea;
        }
        
        @media (max-width: 480px) {
            .verify-container {
                padding: 35px 20px;
            }
            .code-input {
                width: 42px;
                height: 52px;
                font-size: 20px;
            }
            .verify-title {
                font-size: 22px;
            }
        }
    </style>
</head>
<body>
    <div class="verify-container">
        <div class="verify-icon">
            <i class="fas fa-envelope-open-text"></i>
        </div>
        
        <h2 class="verify-title">Verifica tu Email</h2>
        <p class="verify-description">
            Hemos enviado un código de verificación de 6 dígitos a tu correo electrónico. 
            Por favor, ingrésalo a continuación.
        </p>
        
        <div class="code-inputs">
            <input type="text" class="code-input" id="code1" maxlength="1" pattern="[0-9]" inputmode="numeric" autocomplete="off">
            <input type="text" class="code-input" id="code2" maxlength="1" pattern="[0-9]" inputmode="numeric" autocomplete="off">
            <input type="text" class="code-input" id="code3" maxlength="1" pattern="[0-9]" inputmode="numeric" autocomplete="off">
            <input type="text" class="code-input" id="code4" maxlength="1" pattern="[0-9]" inputmode="numeric" autocomplete="off">
            <input type="text" class="code-input" id="code5" maxlength="1" pattern="[0-9]" inputmode="numeric" autocomplete="off">
            <input type="text" class="code-input" id="code6" maxlength="1" pattern="[0-9]" inputmode="numeric" autocomplete="off">
        </div>
        
        <button class="btn-verify" onclick="verifyCode()" id="verifyBtn">
            <span class="loading-spinner"></span>
            <span class="btn-text"><i class="fas fa-check-circle"></i> Verificar</span>
        </button>
        
        <!-- Mensajes -->
        <div class="message" id="messageBox"></div>
        
        <div class="resend-section">
            <button class="resend-btn" id="resendBtn" onclick="resendCode()">
                <i class="fas fa-redo"></i> Reenviar código
            </button>
            <p class="timer" id="timer"></p>
        </div>
        
        <a href="/login" class="back-link">
            <i class="fas fa-arrow-left"></i> Volver al inicio de sesión
        </a>
    </div>
    
    <script>
        // ============ CONFIGURACIÓN DEL TIMER ============
        let timerSeconds = 60;
        let timerInterval = null;
        let canResend = false;
        
        const resendBtn = document.getElementById('resendBtn');
        const timerElement = document.getElementById('timer');
        
        function startTimer() {
            canResend = false;
            resendBtn.disabled = true;
            resendBtn.style.opacity = '0.5';
            timerSeconds = 60;
            
            updateTimerDisplay();
            
            if (timerInterval) clearInterval(timerInterval);
            
            timerInterval = setInterval(() => {
                timerSeconds--;
                updateTimerDisplay();
                
                if (timerSeconds <= 0) {
                    clearInterval(timerInterval);
                    canResend = true;
                    resendBtn.disabled = false;
                    resendBtn.style.opacity = '1';
                    timerElement.textContent = 'Puedes reenviar el código';
                    timerElement.classList.remove('warning');
                }
            }, 1000);
        }
        
        function updateTimerDisplay() {
            if (timerSeconds > 30) {
                timerElement.textContent = `Reenvío disponible en ${timerSeconds}s`;
                timerElement.classList.remove('warning');
            } else if (timerSeconds > 0) {
                timerElement.textContent = `Reenvío disponible en ${timerSeconds}s`;
                timerElement.classList.add('warning');
            }
        }
        
        // Iniciar timer al cargar
        startTimer();
        
        // ============ AUTO-FOCUS ENTRE INPUTS ============
        const inputs = document.querySelectorAll('.code-input');
        
        inputs.forEach((input, index) => {
            // Auto-focus al siguiente input
            input.addEventListener('input', function(e) {
                const value = this.value;
                
                // Solo permitir números
                if (!/^\d$/.test(value)) {
                    this.value = '';
                    return;
                }
                
                this.classList.add('filled');
                this.classList.remove('error');
                
                // Mover al siguiente input
                if (value.length === 1 && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
                
                // Auto-verificar si todos están llenos
                if (index === inputs.length - 1 && value.length === 1) {
                    checkAllFilled();
                }
            });
            
            // Manejar backspace
            input.addEventListener('keydown', function(e) {
                if (e.key === 'Backspace' && !this.value && index > 0) {
                    inputs[index - 1].focus();
                    inputs[index - 1].classList.remove('filled');
                }
                
                // Mover con flechas
                if (e.key === 'ArrowLeft' && index > 0) {
                    inputs[index - 1].focus();
                }
                if (e.key === 'ArrowRight' && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
                
                // Verificar con Enter
                if (e.key === 'Enter') {
                    verifyCode();
                }
            });
            
            // Pegar código completo
            input.addEventListener('paste', function(e) {
                e.preventDefault();
                const pastedData = (e.clipboardData || window.clipboardData).getData('text');
                const numbers = pastedData.replace(/\D/g, '').substring(0, 6);
                
                if (numbers.length > 0) {
                    numbers.split('').forEach((num, i) => {
                        if (inputs[i]) {
                            inputs[i].value = num;
                            inputs[i].classList.add('filled');
                        }
                    });
                    
                    // Focus en el último input lleno
                    const lastIndex = Math.min(numbers.length, inputs.length) - 1;
                    if (inputs[lastIndex]) {
                        inputs[lastIndex].focus();
                    }
                    
                    if (numbers.length === 6) {
                        verifyCode();
                    }
                }
            });
        });
        
        function checkAllFilled() {
            const allFilled = Array.from(inputs).every(input => input.value.length === 1);
            if (allFilled) {
                // Pequeño delay para que se vea el último número
                setTimeout(verifyCode, 300);
            }
        }
        
        // Focus en el primer input
        inputs[0].focus();
        
        // ============ VERIFICAR CÓDIGO ============
        async function verifyCode() {
            const code = Array.from(inputs).map(input => input.value).join('');
            
            if (code.length !== 6) {
                showMessage('Por favor, ingresa el código completo de 6 dígitos', 'error');
                shakeInputs();
                return;
            }
            
            const btn = document.getElementById('verifyBtn');
            btn.classList.add('loading');
            btn.disabled = true;
            
            try {
                const response = await fetch('/verify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ code })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    showMessage('✅ ' + data.message, 'success');
                    
                    // Redirigir al login después de 2 segundos
                    setTimeout(() => {
                        window.location.href = '/login?verified=true';
                    }, 2000);
                } else {
                    showMessage('❌ ' + data.message, 'error');
                    shakeInputs();
                    clearInputs();
                    inputs[0].focus();
                }
            } catch (error) {
                showMessage('Error de conexión. Intenta de nuevo.', 'error');
            } finally {
                btn.classList.remove('loading');
                btn.disabled = false;
            }
        }
        
        // ============ REENVIAR CÓDIGO ============
        async function resendCode() {
            if (!canResend) {
                showMessage(`Espera ${timerSeconds} segundos para reenviar`, 'info');
                return;
            }
            
            resendBtn.disabled = true;
            resendBtn.innerHTML = '<span class="loading-spinner" style="display:inline-block;width:14px;height:14px;border:2px solid rgba(102,126,234,0.3);border-top-color:#667eea;border-radius:50%;animation:spin 0.6s linear infinite;"></span> Enviando...';
            
            try {
                const response = await fetch('/resend-verification', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                const data = await response.json();
                
                if (data.success) {
                    showMessage('✅ Nuevo código enviado a tu email', 'success');
                    clearInputs();
                    inputs[0].focus();
                    startTimer(); // Reiniciar timer
                } else {
                    // Si la sesión expiró, redirigir al login
                    if (data.message && data.message.includes('Sesión expirada')) {
                        showMessage('Sesión expirada. Redirigiendo al login...', 'error');
                        setTimeout(() => {
                            window.location.href = '/login';
                        }, 2000);
                    } else {
                        showMessage('❌ ' + (data.message || 'Error al reenviar'), 'error');
                        canResend = true;
                        resendBtn.disabled = false;
                    }
                }
            } catch (error) {
                showMessage('Error de conexión', 'error');
                canResend = true;
                resendBtn.disabled = false;
            } finally {
                resendBtn.innerHTML = '<i class="fas fa-redo"></i> Reenviar código';
                if (!canResend) {
                    resendBtn.disabled = true;
                }
            }
        }
        
        // ============ HELPERS ============
        function clearInputs() {
            inputs.forEach(input => {
                input.value = '';
                input.classList.remove('filled', 'error');
            });
        }
        
        function shakeInputs() {
            inputs.forEach(input => {
                input.classList.add('error');
                setTimeout(() => input.classList.remove('error'), 500);
            });
        }
        
        function showMessage(message, type) {
            const msgBox = document.getElementById('messageBox');
            const icons = {
                success: '<i class="fas fa-check-circle"></i> ',
                error: '<i class="fas fa-exclamation-circle"></i> ',
                info: '<i class="fas fa-info-circle"></i> '
            };
            
            msgBox.innerHTML = (icons[type] || '') + message;
            msgBox.className = 'message ' + type + ' show';
            
            // Auto-ocultar mensajes de éxito
            if (type === 'success') {
                setTimeout(() => {
                    msgBox.classList.remove('show');
                }, 5000);
            }
        }
        
        // ============ PEGAR CÓDIGO DESDE CUALQUIER PARTE ============
        document.addEventListener('paste', function(e) {
            // Solo si el foco no está en un input
            if (!document.activeElement || !document.activeElement.classList.contains('code-input')) {
                const pastedData = (e.clipboardData || window.clipboardData).getData('text');
                const numbers = pastedData.replace(/\D/g, '').substring(0, 6);
                
                if (numbers.length === 6) {
                    numbers.split('').forEach((num, i) => {
                        if (inputs[i]) {
                            inputs[i].value = num;
                            inputs[i].classList.add('filled');
                        }
                    });
                    verifyCode();
                }
            }
        });
    </script>
</body>
</html>